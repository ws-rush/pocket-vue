  {
    "id": "tests-for",
    "category": "Tests",
    "title": "v-for",
    "description": "Test demo from /tests/for.html",
    "code": "<script type=\"module\">\n  import { createApp } from 'https://esm.sh/pocket-vue'\n\n  let id = 4\n  createApp({\n    list: [\n      { id: 1, text: 'bar' },\n      { id: 2, text: 'boo' },\n      { id: 3, text: 'baz' },\n      { id: 4, text: 'bazz' }\n    ],\n    add() {\n      this.list.push({ id: ++id, text: 'new item' })\n    },\n    splice() {\n      this.list.splice(1, 0, { id: ++id, text: 'new item' })\n    }\n  }).mount('#app')\n</script>\n\n<div id=\"app\">\n  <button @click=\"add\">add</button>\n  <button @click=\"list.reverse()\">reverse</button>\n  <button @click=\"list.pop()\">pop</button>\n  <button @click=\"splice\">splice</button>\n  <ul>\n    <li v-for=\"({ id, text }, index) in list\" :key=\"id\">\n      <div>{{ index }} {{ { id, text } }}</div>\n    </li>\n  </ul>\n\n  <ul>\n    <li v-for=\"item of list\" :key=\"item.id\">\n      <input v-model=\"item.text\" />\n    </li>\n  </ul>\n</div>\n",
    "source": "/tests/for.html"
  },
  {
    "id": "tests-html",
    "category": "Tests",
