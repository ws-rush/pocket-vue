    "title": "v-bind",
    "description": "Test demo from /tests/bind.html",
    "code": "<style>\n  #green {\n    color: green;\n  }\n  .red {\n    color: red;\n  }\n  .orange {\n    color: orange;\n  }\n  .static {\n    font-weight: bold;\n  }\n  [v-cloak] {\n    opacity: 0;\n  }\n</style>\n\n<script type=\"module\">\n  import { createApp, reactive } from 'https://esm.sh/pocket-vue'\n\n  // for testing\n  const data = (window.data = reactive({\n    id: 'green',\n    classes: ['foo', { red: true }],\n    style: { color: 'blue' },\n    obj: {\n      class: 'orange'\n    }\n  }))\n\n  createApp(data).mount()\n</script>\n\n<div v-scope v-cloak>\n  <div :id=\"id\">simple binding - this should be green</div>\n  <div class=\"static\" :class=\"classes\">\n    class binding - this should be red and bold\n  </div>\n  <div style=\"font-weight: bold\" :style=\"style\">\n    style binding - this should be blue and bold\n  </div>\n  <div v-bind=\"obj\">object binding - this should be orange</div>\n</div>\n",
    "source": "/tests/bind.html"
  },
