  {
    "id": "examples-commits",
    "category": "Examples",
    "title": "Commits",
    "description": "Example demo from /examples/commits.html",
    "code": "<script type=\"module\">\n  import { createApp, reactive } from 'https://esm.sh/pocket-vue'\n\n  const API_URL = `https://api.github.com/repos/microsoft/vscode/commits?per_page=3&sha=`\n\n  createApp({\n    branches: ['main', 'release/1.90'],\n    currentBranch: 'main',\n    commits: null,\n\n    truncate(v) {\n      const newline = v.indexOf('\\n')\n      return newline > 0 ? v.slice(0, newline) : v\n    },\n\n    formatDate(v) {\n      return v.replace(/T|Z/g, ' ')\n    },\n\n    fetchData() {\n      fetch(`${API_URL}${this.currentBranch}`)\n        .then((res) => res.json())\n        .then((data) => {\n          this.commits = data\n        })\n    }\n  }).mount()\n</script>\n\n<div v-scope v-effect=\"fetchData()\">\n  <h1>Latest Visual Sudio Code Commits\n</h1>\n  <template v-for=\"branch in branches\">\n    <input\n      type=\"radio\"\n      :id=\"branch\"\n      :value=\"branch\"\n      name=\"branch\"\n      v-model=\"currentBranch\"\n    />\n    <label :for=\"branch\">{{ branch }}</label>\n  </template>\n  <p>microsoft/vscode@{{ currentBranch }}</p>\n  <ul>\n    <li v-for=\"{ html_url, sha, author, commit } in commits\">\n      <a :href=\"html_url\" target=\"_blank\" class=\"commit\"\n        >{{ sha.slice(0, 7) }}</a\n      >\n      - <span class=\"message\">{{ truncate(commit.message) }}</span><br />\n      by\n      <span class=\"author\"\n        ><a :href=\"author.html_url\" target=\"_blank\"\n          >{{ commit.author.name }}</a\n        ></span\n      >\n      at <span class=\"date\">{{ formatDate(commit.author.date) }}</span>\n    </li>\n  </ul>\n</div>\n\n<style>\n  body {\n    font-family: 'Helvetica', Arial, sans-serif;\n  }\n  a {\n    text-decoration: none;\n    color: #f66;\n  }\n  li {\n    line-height: 1.5em;\n    margin-bottom: 20px;\n  }\n  .author, .date {\n    font-weight: bold;\n  }\n</style>\n",
    "source": "/examples/commits.html"
  },
